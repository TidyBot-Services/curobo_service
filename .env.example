# Copy to .env. .env is gitignored.

# --- Service binding ---
# CUROBO_HOST=127.0.0.1
# CUROBO_PORT=7000
# CUROBO_LOG_LEVEL=info

# --- cuRobo runtime ---
# CUROBO_DEVICE=cuda:0          # GPU device for cuRobo kernels
# CUROBO_ROBOT_CFG=franka_tidyverse.yml   # robot YML in assets/

# --- Asset path (where the .yml + sphere configs live) ---
# Defaults to <package>/assets/. Override if you keep a curated set elsewhere.
# CUROBO_ASSETS_DIR=/abs/path/to/curobo_assets

# --- Multi-tenancy ---
# CUROBO_DEFAULT_ENV=default    # env_id used when caller doesn't specify
# CUROBO_MAX_ENVS=8             # cap on simultaneous world states
